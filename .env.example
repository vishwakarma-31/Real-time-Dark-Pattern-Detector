# DarkScan environment variables
# Copy this to .env and fill in your actual values

# Required
OPENAI_API_KEY=sk-placeholder-replace-with-real-key
MONGO_URI=mongodb://mongo:27017/darkscan
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_RUN: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Optional (defaults applied by server.js)
# PORT=5000
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# ANALYSIS_CACHE_TTL=600
# RATE_LIMIT_MAX_REQUESTS=20
# NODE_ENV=development
VISION_DAILY_LIMIT=200
USER_DAILY_ANALYSIS_LIMIT=50
ANON_DAILY_ANALYSIS_LIMIT=5
