{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dark Pattern Annotation Schema",
  "description": "JSON schema for a single annotated screenshot entry representing detected dark patterns.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the annotation record."
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "The URL of the page where the pattern was detected."
    },
    "screenshot_path": {
      "type": "string",
      "description": "Relative or absolute path to the stored screenshot file."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the annotation was created."
    },
    "annotator": {
      "type": "string",
      "description": "Name or ID of the human or system bounding the pattern."
    },
    "patterns_detected": {
      "type": "array",
      "description": "List of distinct dark patterns found in the viewport.",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "fake_countdown",
              "hidden_cost",
              "roach_motel",
              "trick_question",
              "forced_continuity",
              "confirm_shaming"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Detection confidence score."
          },
          "dom_element_selector": {
            "type": "string",
            "description": "The CSS selector targeting the malicious element."
          },
          "bounding_box": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "w": { "type": "number" },
              "h": { "type": "number" }
            },
            "required": ["x", "y", "w", "h"]
          },
          "evidence_text": {
            "type": "string",
            "description": "The specific text content that triggered the classification."
          }
        },
        "required": [
          "category",
          "confidence",
          "dom_element_selector",
          "bounding_box",
          "evidence_text"
        ]
      }
    },
    "overall_severity": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Cumulative assessment of manipulation severity."
    },
    "notes": {
      "type": "string",
      "description": "Any remaining context regarding this annotation."
    }
  },
  "required": [
    "id",
    "url",
    "screenshot_path",
    "timestamp",
    "annotator",
    "patterns_detected",
    "overall_severity"
  ],
  "examples": [
    {
      "id": "e98e4f12-0a14-4eb9-a29d-9226d953932e",
      "url": "https://www.booking.com/hotel/checkout",
      "screenshot_path": "/data/images/booking_01.png",
      "timestamp": "2026-04-04T12:00:00Z",
      "annotator": "researcher_01",
      "patterns_detected": [
        {
          "category": "fake_countdown",
          "confidence": 0.98,
          "dom_element_selector": "div.timer-alert span.countdown",
          "bounding_box": { "x": 140.5, "y": 80.0, "w": 200, "h": 40 },
          "evidence_text": "Hurry! Deal ends in 04:32"
        }
      ],
      "overall_severity": "medium",
      "notes": "Timer resets upon clearing cookies."
    },
    {
      "id": "4da426b3-e28a-44e2-89cd-f7a35fe6a12b",
      "url": "https://www.zomato.com/order/summary",
      "screenshot_path": "/data/images/zomato_donation.png",
      "timestamp": "2026-04-04T12:15:30Z",
      "annotator": "researcher_02",
      "patterns_detected": [
        {
          "category": "hidden_cost",
          "confidence": 0.95,
          "dom_element_selector": "input#donate-charity-checkbox",
          "bounding_box": { "x": 100, "y": 650, "w": 300, "h": 25 },
          "evidence_text": "Convenience fee 45 INR added"
        }
      ],
      "overall_severity": "medium",
      "notes": "Pre-checked donation added to total without clear visual separation."
    },
    {
      "id": "76af5d99-52e8-466d-ad0f-cf92ec4ad0ca",
      "url": "https://www.amazon.com/prime/cancel",
      "screenshot_path": "/data/images/amazon_prime_cancel.png",
      "timestamp": "2026-04-04T12:35:45Z",
      "annotator": "auto_detector_v1",
      "patterns_detected": [
        {
          "category": "confirm_shaming",
          "confidence": 0.89,
          "dom_element_selector": "a#decline-benefits-link",
          "bounding_box": { "x": 400, "y": 900, "w": 250, "h": 20 },
          "evidence_text": "I prefer paying full price for shipping"
        },
        {
          "category": "roach_motel",
          "confidence": 0.82,
          "dom_element_selector": "button#contact-support-cancel",
          "bounding_box": { "x": 400, "y": 950, "w": 150, "h": 40 },
          "evidence_text": "Contact support to unsubscribe"
        }
      ],
      "overall_severity": "high",
      "notes": "Multi-step cancellation process with heavy emotional language."
    }
  ]
}
